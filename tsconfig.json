{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "declaration": false,
    "outDir": "build",
    "rootDir": ".",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "types": ["react"]
  },
  "include": [
    "src/app/**/*",
    "src/hooks/useParentConsoleData.ts",
    "src/lib/supabase/**/*",
    "src/providers/**/*",
    "src/types/**/*",
    "src/constants/**/*"
  ]
}
